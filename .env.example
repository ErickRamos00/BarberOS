# ===== SEÇÃO DE DESENVOLVIMENTO =====
# Copie este arquivo para .env e preencha os valores

# ===== SERVER =====
PORT=3000
HOST=localhost
NODE_ENV=production

# ===== SEGURANÇA =====
# ⚠️ IMPORTANTE: Altere isso em produção!
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=barber-secret-key-change-in-production

# ===== BANCO DE DADOS =====
DATABASE_PATH=./barber.db

# ===== CORS =====
# Em desenvolvimento: * (permite todas as origens)
# Em produção: especifique o domínio, ex: https://seusite.com
CORS_ORIGIN=*
