{
  "name": "barber-system",
  "version": "1.0.0",
  "description": "BarberOS - Sistema profissional de agendamento para barbearias",
  "main": "server.js",
  "author": "BarberOS",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development node server.js",
    "production": "cross-env NODE_ENV=production node server.js",
    "seed": "node scripts/seed.js && npm start",
    "test": "node scripts/test-api.js",
    "lint": "eslint . --ignore-pattern node_modules",
    "format": "prettier --write '**/*.js'",
    "audit": "npm audit",
    "audit-fix": "npm audit fix",
    "backup": "node scripts/backup.js",
    "migrate": "node scripts/migrate.js",
    "check": "node scripts/pre-deploy.js"
  },
  "keywords": [
    "barber",
    "barbearia",
    "scheduling",
    "agendamento",
    "appointment",
    "sistema",
    "saas"
  ],
  "engines": {
    "node": "20.x",
    "npm": ">=6.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seu-usuario/barberos.git"
  },
  "homepage": "https://barberos.app",
  "bugs": {
    "url": "https://github.com/seu-usuario/barberos/issues"
  }
}
